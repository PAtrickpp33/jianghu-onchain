{
  "$comment": "Example Claude Code MCP config for Xiake Arena — copy into ~/.config/claude-code/mcp.json (or the equivalent Cursor/Codex config) and fill in the real values.",
  "mcpServers": {
    "xiake": {
      "command": "node",
      "args": ["./dist/index.js"],
      "env": {
        "BASE_SEPOLIA_RPC": "https://sepolia.base.org",
        "XIAKE_HERO_ADDRESS": "0x0000000000000000000000000000000000000000",
        "XIAKE_ARENA_ADDRESS": "0x0000000000000000000000000000000000000000",
        "XIAKE_VAULT_ADDRESS": "0x0000000000000000000000000000000000000000",

        "OKX_API_KEY": "replace-me",
        "OKX_SECRET_KEY": "replace-me",
        "OKX_PASSPHRASE": "replace-me",
        "OKX_PROJECT_ID": "replace-me",

        "ANTHROPIC_API_KEY": "replace-me"
      }
    },
    "xiake-npx": {
      "$comment": "Alternative: use published npm package instead of a local build.",
      "command": "npx",
      "args": ["-y", "xiake-skill"],
      "env": {
        "BASE_SEPOLIA_RPC": "https://sepolia.base.org",
        "XIAKE_HERO_ADDRESS": "0x...",
        "XIAKE_ARENA_ADDRESS": "0x...",
        "XIAKE_VAULT_ADDRESS": "0x...",
        "OKX_API_KEY": "...",
        "OKX_SECRET_KEY": "...",
        "OKX_PASSPHRASE": "...",
        "OKX_PROJECT_ID": "...",
        "ANTHROPIC_API_KEY": "..."
      }
    }
  }
}
