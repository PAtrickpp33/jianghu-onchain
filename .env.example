# ============================================================================
# Xiake Arena · Environment Template
# ----------------------------------------------------------------------------
# Copy this file to .env and fill in the blanks. NEVER commit .env.
# Every variable below is referenced by scripts/setup.sh, the Foundry
# deploy script, or the xiake-skill MCP server.
# ============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# 1. OnchainOS (OKX Developer Portal)
#    Get these from https://www.okx.com/web3/dev-portal → Create Project
#    Scope required: Wallet API, Onchain Gateway, Paymaster, Security.
# ─────────────────────────────────────────────────────────────────────────────
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# Paymaster policy id (sponsors gas for HeroNFT + Arena methods).
# Create in Dev-Portal → Paymaster → Policies.
OKX_PAYMASTER_POLICY_ID=

# OnchainOS base URL. Default prod URL; override for staging.
OKX_API_BASE_URL=https://www.okx.com


# ─────────────────────────────────────────────────────────────────────────────
# 2. Anthropic (caster agent + optional AI vs AI players)
#    https://console.anthropic.com/settings/keys
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Models used by the skill.
# Haiku = fast/cheap caster. Sonnet = default AI-vs-AI player.
CASTER_MODEL=claude-haiku-4-5
AGENT_A_MODEL=claude-sonnet-4-5
AGENT_B_MODEL=claude-haiku-4-5


# ─────────────────────────────────────────────────────────────────────────────
# 3. Chain / RPC
#    Base Sepolia is the hackathon target. Chain id 84532.
# ─────────────────────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
CHAIN_ID=84532

# Optional: BaseScan API key for contract verification.
BASESCAN_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# 4. Deployer (only needed for scripts/setup.sh the first time)
#    NEVER use a key that has funds on mainnet. Dev-only.
#    Get test ETH: https://www.coinbase.com/faucets/base-ethereum-sepolia-faucet
# ─────────────────────────────────────────────────────────────────────────────
DEPLOYER_PK=

# Vault / HeroNFT owner — the ONLY address that can schedule + execute
# withdrawals from GachaVault. Keep this in a hardware wallet; the deployer
# key is not authorised to touch gacha funds.
OWNER_ADDRESS=


# ─────────────────────────────────────────────────────────────────────────────
# 5. Deployed contract addresses (Base Sepolia · chainId 84532)
#
# These are PUBLIC — everyone plays on the same shared testnet deployment.
# BaseScan verifies them at https://sepolia.basescan.org/address/<addr>.
# Only change them if you've deployed your own fork of the contracts.
#
# Current deployment: 2026-04-20 · Arena v3 (chapter-fix + rep-gate).
# ─────────────────────────────────────────────────────────────────────────────
XIAKE_HERO_ADDRESS=0x056bB8B1AeaaF4e5eB6a6b016fDE80C60e100f4A
XIAKE_ARENA_ADDRESS=0x567aE39f1E1081E85a1d13b7135ef2d3Ea1FcC61
XIAKE_VAULT_ADDRESS=0x47135Ba1F3D9674869a63da07f40e42a57318A44
XIAKE_STAGES_ADDRESS=0x613497e20D196952f169B316fd7Ad8f8eb519df7
SKILL_REGISTRY_ADDRESS=0xC1b36B703A349e2fB1B29c4B912C3144Ab69f3E1


# ─────────────────────────────────────────────────────────────────────────────
# 6. Skill runtime flags (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Set to 1 to force plain-text rendering (disable ANSI colors).
XIAKE_NO_COLOR=0

# Set to 1 to print every outbound OnchainOS request (verbose debug).
XIAKE_DEBUG=0

# Terminal width hint for ASCII layout. Auto-detected when unset.
XIAKE_TERM_WIDTH=

# Demo day overrides — points the skill at an anvil fork instead of live RPC.
# Leave blank in production.
XIAKE_LOCAL_FORK_RPC=
